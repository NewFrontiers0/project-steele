# Optional: space-separated firmware repository/image URLs for unattended startup.
# Leave blank to choose the firmware source host and port in the web UI.
FIRMWARE_URLS=

# Optional SWIM HTTP streaming profile for Catalyst downloads.
# Options: balanced, safe, fast, custom.
# Use safe to roll back to the original slow profile if a switch dislikes balanced.
SWIM_HTTP_PROFILE=balanced
SWIM_HTTP_CHUNK_BYTES=512
SWIM_HTTP_CHUNK_DELAY_MS=1
SWIM_HTTP_ACCELERATE_AFTER_BYTES=262144
SWIM_HTTP_ACCELERATED_CHUNK_BYTES=8192
SWIM_HTTP_ACCELERATED_CHUNK_DELAY_MS=0
SWIM_HTTP_INITIAL_DELAY_MS=100
SWIM_HTTP_TCP_MAXSEG=536
SWIM_HTTP_SNDBUF_BYTES=8192
SWIM_HTTP_TCP_NOTSENT_LOWAT=4096
