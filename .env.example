# Optional: space-separated firmware repository/image URLs for unattended startup.
# Leave blank to choose the firmware source host and port in the web UI.
FIRMWARE_URLS=

# Optional: conservative SWIM HTTP streaming profile for Catalyst downloads.
SWIM_HTTP_CHUNK_BYTES=512
SWIM_HTTP_CHUNK_DELAY_MS=5
SWIM_HTTP_INITIAL_DELAY_MS=500
SWIM_HTTP_TCP_MAXSEG=536
SWIM_HTTP_SNDBUF_BYTES=4096
